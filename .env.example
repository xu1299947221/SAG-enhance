NODE_ENV=development
LOG_LEVEL=info
HTTP_HOST=0.0.0.0
HTTP_PORT=4173

DATABASE_URL=postgres://sag_lite:sag_lite_pass@localhost:5432/sag_lite
DEFAULT_TENANT_ID=default
AUTH_MODE=none

EMBEDDING_DIMENSIONS=1024
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.302ai.cn/v1

LLM_MODEL=qwen3.6-flash
LLM_API_KEY=
LLM_BASE_URL=https://api.302ai.cn/v1
LLM_TIMEOUT_MS=60000
LLM_MAX_RETRIES=2
RERANK_MODEL=qwen3-rerank
RERANK_INSTRUCT=Given a user question, rank SAG event candidates by relevance and usefulness for retrieval-augmented question answering.
DEFAULT_SEARCH_MODE=fast

MCP_TRANSPORT=stdio
MCP_HTTP_PORT=4174
MCP_TOOL_TIMEOUT_MS=300000
