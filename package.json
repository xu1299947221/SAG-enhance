{
  "name": "sag",
  "version": "0.1.0",
  "description": "SAG: event-centric retrieval with TypeScript, PostgreSQL/pgvector, HTTP and MCP interfaces.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch src/index.ts",
    "dev:web": "vite --host 0.0.0.0",
    "start": "node dist/src/index.js",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && npm run build:api && npm run build:web",
    "build:api": "tsc -p tsconfig.build.json",
    "build:web": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p web/tsconfig.json --noEmit",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:setup": "npm run db:migrate && npm run seed",
    "seed": "tsx src/db/seed.ts",
    "mcp": "SAG_LOG_STDERR=true tsx src/mcp/server.ts",
    "demo:ingest": "tsx scripts/demo-ingest.ts",
    "demo:search": "tsx scripts/demo-search.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@modelcontextprotocol/sdk": "^1.13.0",
    "@xyflow/react": "^12.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "gpt-tokenizer": "^3.4.0",
    "lucide-react": "^1.17.0",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
